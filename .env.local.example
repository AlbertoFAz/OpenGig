# Supabase — valores que da `supabase start` al levantar el stack local
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Web Push / VAPID — generar con: npx web-push generate-vapid-keys
# La clave pública debe llevar el prefijo NEXT_PUBLIC_ para estar disponible en el cliente
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=admin@opengig.app
